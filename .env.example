# =========================================================
# Peaceful Nights Guide — environment variables
# Copy this file to ".env" for local use, or set these in the
# Render dashboard (Environment tab) for production.
# Never commit your real .env file — it is gitignored.
#
# Load locally with:  node --env-file=.env server.js
# =========================================================

# ---- Admin login (used at /admin/login.html) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- Database ----
# PostgreSQL connection string. When set, the app uses Postgres.
# On Render, link your managed Postgres (use its Internal
# Connection String) and this is provided automatically.
# Leave it unset locally to use the simple JSON-file store.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Set to "disable" only if your Postgres does NOT use SSL.
# Render's managed Postgres uses SSL, so leave this unset there.
# PGSSL=disable

# ---- JSON-file fallback (only used when DATABASE_URL is unset) ----
# Folder where the fallback database file is stored.
# Locally you can leave this unset (defaults to ./.data).
# DATA_DIR=/var/data

# ---- Server ----
# Port the server listens on. Render sets this automatically —
# leave it unset there. Locally it defaults to 3000 if omitted.
# PORT=3000

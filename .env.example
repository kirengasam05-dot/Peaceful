# =========================================================
# Peaceful Nights Guide — environment variables
# Copy this file to ".env" for local use, or set these in the
# Render dashboard (Environment tab) for production.
# Never commit your real .env file — it is gitignored.
# =========================================================

# Admin login credentials for /admin/login.html
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# PostgreSQL connection string. When set, the app uses Postgres
# as its database. On Render, link your managed Postgres and it
# provides this automatically. Leave it unset locally to use the
# simple JSON-file store instead.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Only used by the JSON-file fallback store (when DATABASE_URL is
# NOT set). Locally you can leave this unset (defaults to ./.data).
DATA_DIR=/var/data

# Port the server listens on.
# Render sets this automatically — leave it unset there.
# Locally it defaults to 3000 if omitted.
PORT=3000
